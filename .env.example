# Ecommerce-Agent Environment Variables

# LLM Provider (used by external AI tools)
LLM_API_KEY=
LLM_MODEL=

# Project paths (relative to project root)
PROJECT_ROOT=.
INPUT_DIR=./Input
OUTPUT_DIR=./Output

# Gem Image API (if applicable)
GEM_IMAGE_API_ENDPOINT=
GEM_IMAGE_API_KEY=

# Catalog server
CATALOG_PORT=3000
