# Ecommerce-Agent Environment Variables v0.6.2

# === LLM Provider ===
LLM_API_KEY=
LLM_MODEL=

# === Project Paths ===
PROJECT_ROOT=.
INPUT_DIR=./Input
OUTPUT_DIR=./Output

# === Vertex AI Imagen (image-generator) ===
GOOGLE_CLOUD_PROJECT=
# Setup: gcloud auth application-default login

# === Shopify (hpdun.com) ===
SHOPIFY_STORE_URL=https://hpdun.com
SHOPIFY_ACCESS_TOKEN=
# Create at: Shopify Admin → Settings → Apps → Develop apps

# === Facebook (HPD) ===
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=
# Create at: Meta Business Suite → Settings → API

# === TikTok (@hpdun3) ===
TIKTOK_ACCESS_TOKEN=
# Create at: TikTok for Business → Developer

# === Catalog Server ===
CATALOG_PORT=3000
